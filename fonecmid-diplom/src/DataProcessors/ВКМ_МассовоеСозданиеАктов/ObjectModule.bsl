
&НаСервере
Процедура ЗаполнитьДоговоры() Экспорт
	
	Договоры.Очистить();
	
	Если Период = Неопределено Или Период = Дата(1, 1, 1) Тогда
		Возврат;
	КонецЕсли;
	
	НачалоПериода = НачалоМесяца(Период);
	КонецПериода = КонецМесяца(Период);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка КАК Договор
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
	|	И ДоговорыКонтрагентов.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Стр = Договоры.Добавить();
		Стр.Договор = Выборка.Договор;
		
		Реализация = НайтиРеализациюЗаПериод(Выборка.Договор, НачалоПериода, КонецПериода);
		Стр.Реализация = Реализация;
		Стр.Создана = ЗначениеЗаполнено(Реализация);
		
		Если Стр.Создана Тогда
			Стр.Комментарий = "Уже существует";
		Иначе
			Стр.Комментарий = "";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьСозданиеНаСервере(Параметры) Экспорт
	
	Период = Параметры.Период;
	
	Договоры.Очистить();
	Для Каждого Элемент Из Параметры.Договоры Цикл
		Стр = Договоры.Добавить();
		Стр.Договор = Элемент.Договор;
		Стр.Реализация = Неопределено;
		Стр.Создана = Ложь;
		Стр.Комментарий = "";
	КонецЦикла;
	
	СоздатьРеализацииПоДоговорам();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьРеализацииПоДоговорам() Экспорт
	
	Если Период = Неопределено Или Период = Дата(1, 1, 1) Тогда
		ВызватьИсключение "Не указан период.";
	КонецЕсли;
	
	НачалоПериода = НачалоМесяца(Период);
	КонецПериода = КонецМесяца(Период);
	
	Для Каждого Стр Из Договоры Цикл
		
		Если Не ЗначениеЗаполнено(Стр.Договор) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Стр.Реализация) Тогда
			Стр.Создана = Истина;
			Стр.Комментарий = "Уже существует";
			Продолжить;
		КонецЕсли;
		
		СуществующаяРеализация = НайтиРеализациюЗаПериод(Стр.Договор, НачалоПериода, КонецПериода);
		
		Если ЗначениеЗаполнено(СуществующаяРеализация) Тогда
			Стр.Реализация = СуществующаяРеализация;
			Стр.Создана = Истина;
			Стр.Комментарий = "Уже существует";
			Продолжить;
		КонецЕсли;
		
		Попытка
			НоваяРеализация = СоздатьРеализациюПоДоговору(Стр.Договор, КонецПериода);
			Стр.Реализация = НоваяРеализация.Ссылка;
			Стр.Создана = Истина;
			Стр.Комментарий = "Создана";
		Исключение
			Стр.Создана = Ложь;
			Стр.Комментарий = ОписаниеОшибки();
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НайтиРеализациюЗаПериод(Договор, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Реализация.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реализация
	|ГДЕ
	|	Реализация.Договор = &Договор
	|	И Реализация.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И Реализация.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция СоздатьРеализациюПоДоговору(Договор, ДатаДокумента) Экспорт
	
	ДокОбъект = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
	ДокОбъект.Заполнить(Неопределено);
	ДокОбъект.Дата = ДатаДокумента;
	ДокОбъект.Договор = Договор;
	ДокОбъект.Контрагент = Договор.Владелец;
	ДокОбъект.Организация = Договор.Организация;
	
	ДокОбъект.ВКМ_ВыполнитьАвтозаполнение();
	ДокОбъект.ПроверитьЗаполнение();
	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат ДокОбъект;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеДляФормы() Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого Стр Из Договоры Цикл
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("Договор", Стр.Договор);
		СтруктураСтроки.Вставить("Реализация", Стр.Реализация);
		СтруктураСтроки.Вставить("Создана", Стр.Создана);
		СтруктураСтроки.Вставить("Комментарий", Стр.Комментарий);
		Результат.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции
