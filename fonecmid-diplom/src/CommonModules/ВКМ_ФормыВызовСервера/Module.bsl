#Область СлужебныеПроцедурыФункции

Функция СоздатьОбычнуюГруппу(Форма, Вид, Имя, Заголовок, Вертикальная, Родитель, Расположение, ДопСвойства)
	
	Результат = Форма.Элементы.Найти(Имя);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Родитель = Форма;
	КонецЕсли;
	
	Результат = Форма.Элементы.Добавить(Имя, Тип("ГруппаФормы"), Родитель);
	
	Результат.Вид       = Вид;
	Результат.Заголовок = Заголовок;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Результат, "ОтображатьЗаголовок") Тогда
		Результат.ОтображатьЗаголовок = ЗначениеЗаполнено(Заголовок);
	КонецЕсли;
	
	Если Вид <> ВидГруппыФормы.ГруппаКнопок Тогда
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Результат, "Группировка") Тогда
			
			Если ТипЗнч(Результат.Группировка) = Тип("ГруппировкаКолонок") Тогда
				Результат.Группировка = ?(Вертикальная, ГруппировкаКолонок.Вертикальная, ГруппировкаКолонок.Горизонтальная);
			Иначе
				Результат.Группировка = ?(Вертикальная, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипЗнч(ДопСвойства) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(Результат, ДопСвойства);
	КонецЕсли;
	
	Если Расположение <> Неопределено Тогда
		Форма.Элементы.Переместить(Результат, Родитель, Расположение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

