Функция ДобавитьТаблицу(Форма, ПутьКДанным, Имя, Заголовок = "",
	Родитель = Неопределено, Расположение = Неопределено, ДопСвойства = Неопределено) Экспорт
	
	Результат = Форма.Элементы.Найти(Имя);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Родитель = Форма;
	КонецЕсли;
	
	Результат = Форма.Элементы.Добавить(Имя, Тип("ТаблицаФормы"), Родитель);
	Результат.Отображение = ОтображениеТаблицы.Список;
	Результат.ПутьКДанным = ПутьКДанным;
	
	Если ТипЗнч(ДопСвойства) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(Результат, ДопСвойства);
	КонецЕсли;
	
	Если Расположение <> Неопределено Тогда
		Форма.Элементы.Переместить(Результат, Родитель, Расположение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьПоле(Форма, ПутьКДанным, Имя, Заголовок = "", ПолеФлажка = Ложь, ПолеНадписи = Ложь,
	Родитель = Неопределено, Расположение = Неопределено, ДопСвойства = Неопределено) Экспорт
	
	Результат = Форма.Элементы.Найти(Имя);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Родитель = Форма;
	КонецЕсли;
	
	Вид = ВидПоляФормы.ПолеВвода;
	
	Если ПолеФлажка Тогда
		Вид = ВидПоляФормы.ПолеФлажка;
	ИначеЕсли ПолеНадписи Тогда
		Вид = ВидПоляФормы.ПолеНадписи;
	КонецЕсли;
	
	Результат = Форма.Элементы.Добавить(Имя, Тип("ПолеФормы"), Родитель);
	Результат.Вид         = Вид;
	Результат.Заголовок   = Заголовок;
	Результат.ПутьКДанным = ПутьКДанным;
	
	Если ТипЗнч(ДопСвойства) = Тип("Структура") Тогда
		
		ЗаполнитьЗначенияСвойств(Результат, ДопСвойства);
		
		Если ДопСвойства.Свойство("ЗаголовокВПодсказкуВвода") Тогда
			Результат.ПодсказкаВвода     = Заголовок;
			Результат.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет
		КонецЕсли;
		
	КонецЕсли;
	
	Если Расположение <> Неопределено Тогда
		Форма.Элементы.Переместить(Результат, Родитель, Расположение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

