Функция ДобавитьКоманду(Форма, Имя, Действие, Заголовок = "", Картинка = Неопределено) Экспорт
	
	Результат = Форма.Команды.Найти(Имя);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = Форма.Команды.Добавить(Имя);
	Результат.Действие  = Действие;
	Результат.Заголовок = Заголовок;
	
	Если Картинка <> Неопределено Тогда
		Результат.Картинка    = Картинка;
		Результат.Отображение = ОтображениеКнопки.КартинкаИТекст;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьКнопку(Форма, Имя, ИмяКоманды, Гиперссылка = Ложь,
	Родитель = Неопределено, Расположение = Неопределено, ДопСвойства = Неопределено) Экспорт
	
	Результат = Форма.Элементы.Найти(Имя);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Родитель = Форма;
	КонецЕсли;
	
	Результат = Форма.Элементы.Добавить(Имя, Тип("КнопкаФормы"), Родитель);
	
	Результат.ИмяКоманды  = ИмяКоманды;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Результат, "Гиперссылка") Тогда
		Результат.Гиперссылка = Гиперссылка;
	КонецЕсли;
	
	Если ТипЗнч(ДопСвойства) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(Результат, ДопСвойства);
	КонецЕсли;
	
	Если Расположение <> Неопределено Тогда
		Форма.Элементы.Переместить(Результат, Родитель, Расположение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

